    <h3>MAP Instruction Details</h3>

    {[
      ['MNOP'], ['MHALT'],
      ['MADD', 'MADDI'], ['MSUB', 'MSUBI'],
      ['MCMP', 'MCMPI'],
      ['MAND', 'MANDI'], ['MOR', 'MORI'], ['MXOR', 'MXORI'], ['MNOT'],
      ['MSHL', 'MSHLI', 'MSHR', 'MSHRI'],
      ['MCONCAT'],
      ['MMOV', 'MMOVI'],
      ['MFFI'],
      ['MBR', 'MBRI', 'MBRBTST'],
    ].map((group) => (
      group.map((id) => {
        const wavedrom = getEncodingWavedrom('mencdec', id);
        const src = getMexecuteClause(id);
        return (src || wavedrom) ? (
          <div class="instruction-detail">
            <h4>{id}</h4>
            {wavedrom && <script type="WaveDrom" set:text={wavedrom} />}
            {src && <div class="sail-code" set:text={src} />}
          </div>
        ) : null;
      })
    ))}

    <p style="margin-top: 2rem; color: var(--text-dim); font-size: 0.85rem;">
      Sail semantics are auto-generated from the formal model. See the
      <a href="https://github.com/qobilidop/sail-xisa" style="color: var(--accent);">source repository</a>
      for the full model.
    </p>
  </div>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      if (typeof WaveDrom !== 'undefined') {
        WaveDrom.ProcessAll();
      }
    });
  </script>
</Base>
